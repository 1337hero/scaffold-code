#!/usr/bin/env bun
// scaffold — deploy/update the scaffold-code engine into project repos.
// Engine files (BOOT, cookbook) are stock and overwritten by `update`;
// rails/ and memory/ are project-owned and never touched.
// Adapters are NOT copied into projects — `scaffold setup` installs them
// globally per machine (Pi extension, Claude Code hooks, Codex hooks, and
// an opencode plugin).
const fs = require("fs");
const path = require("path");
const crypto = require("crypto");
const { execSync } = require("child_process");

const HOME_REPO = path.resolve(fs.realpathSync(process.argv[1]), "..", "..");
// Keep the canonical engine below template/ so this source repository does not activate the
// runtime hooks intended for deployed projects. `copy` still installs it as <project>/.scaffold.
const SRC = path.join(HOME_REPO, "template", ".scaffold");
const ENGINE = [
  "BOOT.md",
  "cookbook/orient.md",
  "cookbook/loop.md",
  "cookbook/closeout.md",
  "cookbook/closeout-check.sh",
  "hooks/pre-push",
];
const STATE_TEMPLATES = [
  "rails/standards.md",
  "memory/STATE.md",
  "memory/log/2026-06-29-example-closeout.md.example",
];
const REGISTRY = path.join(process.env.HOME, ".config", "scaffold", "projects");

const sh = (cmd, cwd) => {
  try {
    return execSync(cmd, { cwd, stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
  } catch {
    return null;
  }
};
const version = () => {
  const hash = sh("git rev-parse --short HEAD", HOME_REPO) || "unknown";
  const dirty = sh("git status --porcelain -- template/.scaffold bin", HOME_REPO) ? "-dirty" : "";
  return `${hash}${dirty}`;
};
const fileHash = (f) => crypto.createHash("sha256").update(fs.readFileSync(f)).digest("hex");

const registered = () =>
  fs.existsSync(REGISTRY) ? fs.readFileSync(REGISTRY, "utf8").split("\n").filter(Boolean) : [];
const register = (dir) => {
  const list = new Set(registered());
  list.add(dir);
  fs.mkdirSync(path.dirname(REGISTRY), { recursive: true });
  fs.writeFileSync(REGISTRY, [...list].join("\n") + "\n");
};

const copy = (rel, dest, overwrite) => {
  const to = path.join(dest, ".scaffold", rel);
  if (!overwrite && fs.existsSync(to)) return false;
  fs.mkdirSync(path.dirname(to), { recursive: true });
  fs.copyFileSync(path.join(SRC, rel), to);
  return true;
};

// hard-rail enforcement lives in the environment: a git pre-push hook, not command parsing
function installGitHook(dir) {
  const gitDir = sh("git rev-parse --git-dir", dir);
  if (!gitDir) return;
  const dest = path.join(path.resolve(dir, gitDir), "hooks", "pre-push");
  if (fs.existsSync(dest) && !fs.readFileSync(dest, "utf8").includes("scaffold-code")) {
    console.log(
      `warn: existing non-scaffold pre-push hook at ${dest} — not overwritten; chain .scaffold/hooks/pre-push into it manually`,
    );
    return;
  }
  fs.mkdirSync(path.dirname(dest), { recursive: true });
  fs.copyFileSync(path.join(dir, ".scaffold", "hooks", "pre-push"), dest);
  fs.chmodSync(dest, 0o755);
}

const stamp = (dest) =>
  fs.writeFileSync(
    path.join(dest, ".scaffold", "VERSION"),
    `${version()} ${new Date().toISOString().slice(0, 10)}\n`,
  );

function init(dir) {
  if (!fs.existsSync(dir)) {
    fs.mkdirSync(dir, { recursive: true });
    console.log(`created ${dir}`);
  }
  const top = sh("git rev-parse --show-toplevel", dir);
  if (!top) {
    sh("git init", dir);
    console.log("ran git init — the rails assume a git repo");
  } else if (fs.realpathSync(top) !== fs.realpathSync(dir)) {
    die(`.scaffold belongs at the repo root — this is inside ${top}`);
  }
  if (fs.existsSync(path.join(dir, ".scaffold", "BOOT.md")))
    die(`${dir} already has .scaffold/ — use \`scaffold update\``);
  for (const f of ENGINE) copy(f, dir, true);
  for (const f of STATE_TEMPLATES) copy(f, dir, false);
  installGitHook(dir);
  stamp(dir);
  register(dir);
  console.log(`initialized ${dir}/.scaffold (${version()})`);
  console.log("next: fill .scaffold/rails/standards.md and .scaffold/memory/STATE.md");
}

function update(dir) {
  if (!fs.existsSync(path.join(dir, ".scaffold")))
    die(`${dir} has no .scaffold/ — use \`scaffold init\``);
  for (const f of ENGINE) copy(f, dir, true);
  for (const f of STATE_TEMPLATES) copy(f, dir, false); // fill gaps, never overwrite
  installGitHook(dir);
  stamp(dir);
  register(dir);
  console.log(`updated ${dir}/.scaffold engine (${version()})`);
  if (fs.existsSync(path.join(dir, ".scaffold", "adapters")))
    console.log(
      "warn: legacy .scaffold/adapters/ copy in project — adapters are machine-global now (`scaffold setup`); safe to delete",
    );
}

function status(dir) {
  const scaffoldDir = path.join(dir, ".scaffold");
  if (!fs.existsSync(scaffoldDir)) die(`${dir} has no .scaffold/`);
  const vFile = path.join(scaffoldDir, "VERSION");
  const deployed = fs.existsSync(vFile) ? fs.readFileSync(vFile, "utf8").trim() : "(unstamped)";
  const drifted = ENGINE.filter((f) => {
    const to = path.join(scaffoldDir, f);
    return !fs.existsSync(to) || fileHash(to) !== fileHash(path.join(SRC, f));
  });
  const ok = drifted.length === 0;
  console.log(`${dir}: ${ok ? "in sync" : "DRIFT"} — deployed ${deployed}, canonical ${version()}`);
  for (const f of drifted) console.log(`  drifted: .scaffold/${f}`);
  return ok;
}

function setup() {
  // pi: global extension
  const piAgent = path.join(process.env.HOME, ".pi", "agent");
  if (fs.existsSync(piAgent)) {
    const extDir = path.join(piAgent, "extensions");
    fs.mkdirSync(extDir, { recursive: true });
    fs.copyFileSync(path.join(SRC, "adapters", "pi", "scaffold.ts"), path.join(extDir, "scaffold.ts"));
    console.log(`pi: installed ${extDir}/scaffold.ts`);
  } else console.log("pi: ~/.pi/agent not found — skipped");

  // opencode: global plugin — loads for every project, no-ops without .scaffold/BOOT.md
  const opencodeDir = path.join(process.env.HOME, ".config", "opencode");
  if (fs.existsSync(opencodeDir)) {
    const pluginDir = path.join(opencodeDir, "plugins");
    fs.mkdirSync(pluginDir, { recursive: true });
    fs.copyFileSync(
      path.join(SRC, "adapters", "opencode", "scaffold.js"),
      path.join(pluginDir, "scaffold.js"),
    );
    console.log(`opencode: installed ${pluginDir}/scaffold.js`);
  } else console.log("opencode: ~/.config/opencode not found — skipped");

  // Claude Code: global hooks, guarded on .scaffold/ presence in the project
  const claudeDir = path.join(process.env.HOME, ".claude");
  if (!fs.existsSync(claudeDir)) console.log("claude: ~/.claude not found — skipped");
  else {
    const settingsPath = path.join(claudeDir, "settings.json");
    const settings = fs.existsSync(settingsPath)
      ? JSON.parse(fs.readFileSync(settingsPath, "utf8"))
      : {};
    const guard = path.join(SRC, "adapters", "claude-code", "guard.cjs");
    const guarded = (cmd) =>
      `if [ -f "$CLAUDE_PROJECT_DIR/.scaffold/BOOT.md" ]; then ${cmd}; fi`;
    const wanted = {
      // push protection is a git pre-push hook (scaffold init/update), not a PreToolUse parser
      SessionStart: [{ hooks: [
        { type: "command", command: guarded('cat "$CLAUDE_PROJECT_DIR/.scaffold/BOOT.md"') },
      ] }],
      Stop: [{ hooks: [{ type: "command", command: guarded(`node "${guard}"`) }] }],
    };
    const changed = mergeHooks(settings, wanted);
    if (changed) {
      if (fs.existsSync(settingsPath))
        fs.copyFileSync(settingsPath, settingsPath + ".bak-scaffold");
      fs.writeFileSync(settingsPath, JSON.stringify(settings, null, 2) + "\n");
      console.log(`claude: hooks merged into ${settingsPath} (backup: settings.json.bak-scaffold)`);
    } else console.log("claude: hooks already current");
  }

  // Codex: global hooks, with activation and project-root discovery handled by the adapter
  const codexDir = path.join(process.env.HOME, ".codex");
  if (!fs.existsSync(codexDir)) console.log("codex: ~/.codex not found — skipped");
  else {
    const hooksPath = path.join(codexDir, "hooks.json");
    const config = fs.existsSync(hooksPath)
      ? JSON.parse(fs.readFileSync(hooksPath, "utf8"))
      : {};
    const guard = path.join(SRC, "adapters", "codex", "guard.cjs");
    const command = `node "${guard}"`;
    const wanted = {
      SessionStart: [{ hooks: [{ type: "command", command, statusMessage: "Loading scaffold rails" }] }],
      Stop: [{ hooks: [{ type: "command", command, timeout: 30 }] }],
    };
    const changed = mergeHooks(config, wanted);
    if (changed) {
      if (fs.existsSync(hooksPath)) fs.copyFileSync(hooksPath, hooksPath + ".bak-scaffold");
      fs.writeFileSync(hooksPath, JSON.stringify(config, null, 2) + "\n");
      console.log(`codex: hooks merged into ${hooksPath} (review them with /hooks)`);
    } else console.log("codex: hooks already current");
  }
}

function mergeHooks(config, wanted) {
  config.hooks = config.hooks || {};
  let changed = false;
  for (const [event, entries] of Object.entries(wanted)) {
    const existing = config.hooks[event] || [];
    // idempotent + self-updating: drop any prior scaffold entry, then add the current one
    const kept = existing.filter((entry) => !JSON.stringify(entry).includes(".scaffold/"));
    config.hooks[event] = [...kept, ...entries];
    if (JSON.stringify(existing) !== JSON.stringify(config.hooks[event])) changed = true;
  }
  // retire scaffold entries from events we no longer use
  for (const [event, entries] of Object.entries(config.hooks)) {
    if (event in wanted) continue;
    const kept = entries.filter((entry) => !JSON.stringify(entry).includes(".scaffold/"));
    if (kept.length !== entries.length) {
      changed = true;
      if (kept.length) config.hooks[event] = kept;
      else delete config.hooks[event];
    }
  }
  return changed;
}

function die(msg) {
  console.error(`scaffold: ${msg}`);
  process.exit(1);
}

const [cmd, ...args] = process.argv.slice(2);
const all = args.includes("--all");
const dirs = all ? registered() : [path.resolve(args.find((a) => !a.startsWith("--")) || ".")];

switch (cmd) {
  case "init":
    init(dirs[0]);
    break;
  case "update":
    dirs.forEach(update);
    break;
  case "status": {
    const ok = dirs.map(status).every(Boolean);
    process.exit(ok ? 0 : 1);
  }
  case "setup":
    setup();
    break;
  case "list":
    registered().forEach((d) => console.log(d));
    break;
  default:
    console.log(`scaffold — deploy the scaffold-code engine (canonical: ${HOME_REPO})

usage:
  scaffold init <dir>          set up .scaffold/ in a repo (engine + state templates + pre-push hook)
  scaffold update [<dir>|--all] refresh engine files + pre-push hook; never touches rails/ or memory/
  scaffold status [<dir>|--all] show drift against the canonical engine
  scaffold setup               install machine-global adapters (Pi + Claude Code + Codex + opencode)
  scaffold list                registered projects`);
}
